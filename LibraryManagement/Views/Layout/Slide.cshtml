        <div class="row">
            <!-- Begin Category Menu Area -->
            <div class="col-xl-3 col-lg-4">
                <!--Category Menu Start-->
                @Html.Action("Navbar","Home")
                <!--Category Menu End-->
            </div>
            <!-- Category Menu Area End Here -->
            <!-- Begin Slider Area -->
